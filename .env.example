GEMINI_API_KEY=your_api_key_here
VAULT_PATH=D:/Study/Gemini Voice/MyBrain

# Token threshold for the gentle "let's wrap up" reminder. When the cumulative
# session token count crosses this, the server injects config/threshold_reminder.md
# into the live session exactly once, prompting the agent to suggest the user
# start a fresh session at a natural pause.
TOKEN_THRESHOLD=65000
